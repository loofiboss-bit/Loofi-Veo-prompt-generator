{
  "name": "veo-prompt-generator",
  "private": true,
  "description": "Professional prompt generator for Google Veo and OpenAI Sora",
  "author": "Loofi",
  "version": "3.2.0",
  "bin": {
    "veo": "./src/cli/index.ts"
  },
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --ignore-pattern \"dist/**\" --ignore-pattern \"release/**\"",
    "lint:ci": "node scripts/lint-ci.mjs",
    "lint:changed:strict": "bash scripts/lint-changed-strict.sh",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --environment jsdom",
    "preview": "vite preview",
    "start": "vite preview --host --port 8080",
    "electron": "vite build && electron .",
    "electron:dev": "concurrently \"vite\" \"wait-on tcp:8080 && electron .\"",
    "dist": "vite build && electron-builder",
    "prepare": "husky",
    "validate": "npm run lint:ci && npm run typecheck && npm run test && npm run format:check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:watch": "vitest --environment jsdom",
    "test:coverage": "vitest run --environment jsdom --coverage",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "cli": "node --import tsx src/cli/index.ts",
    "cli:help": "node --import tsx src/cli/index.ts --help"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint"
    ],
    "*.{ts,tsx,js,jsx,json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.10",
    "@ffmpeg/util": "^0.12.1",
    "@google/genai": "^1.41.0",
    "@mediapipe/tasks-vision": "^0.10.9",
    "@xenova/transformers": "^2.17.2",
    "i18next": "^25.8.10",
    "i18next-browser-languagedetector": "^8.2.1",
    "idb-keyval": "^6.2.1",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^3.8.2",
    "jszip": "^3.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^7.13.0",
    "simple-peer": "^9.11.1",
    "y-webrtc": "^10.3.0",
    "yjs": "^13.6.18",
    "zundo": "^2.1.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.1",
    "electron": "^40.4.1",
    "electron-builder": "^26.7.0",
    "eslint": "^9.39.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.4.39",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^5.3.4",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.loofi.veo",
    "productName": "Veo Prompt Generator",
    "buildDependenciesFromSource": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "publish": {
      "provider": "github",
      "owner": "loofitheboss",
      "repo": "Loofi-Veo-prompt-generator"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${os}-${arch}-setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-${os}-${arch}-portable.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Veo Studio"
    }
  }
}
