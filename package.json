{
  "name": "veo-prompt-generator",
  "private": true,
  "description": "A prompt generator for Veo video models",
  "author": "Loofi",
  "version": "1.5.0-rc.1",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "vite preview --host --port 8080",
    "electron": "vite build && electron .",
    "electron:dev": "concurrently \"vite\" \"wait-on tcp:8080 && electron .\"",
    "dist": "vite build && electron-builder"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.10",
    "@ffmpeg/util": "^0.12.1",
    "@google/genai": "^1.40.0",
    "@mediapipe/tasks-vision": "^0.10.9",
    "@vitejs/plugin-react": "^4.3.1",
    "@xenova/transformers": "^2.17.2",
    "idb-keyval": "^6.2.1",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "jszip": "^3.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simple-peer": "^9.11.1",
    "vite": "^5.3.4",
    "y-webrtc": "^10.3.0",
    "yjs": "^13.6.18",
    "zundo": "^2.1.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.1",
    "electron": "^40.2.1",
    "electron-builder": "^26.7.0",
    "eslint": "^9.39.2",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.3",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.loofi.veo",
    "productName": "Veo Prompt Generator",
    "electronDownload": {
      "cache": "$HOME/.cache/electron",
      "mirror": "https://github.com/electron/electron/releases/download/"
    },
    "buildDependenciesFromSource": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Veo Studio"
    }
  }
}
