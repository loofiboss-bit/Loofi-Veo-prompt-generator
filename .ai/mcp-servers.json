{
  "$schema": "https://veo-studio.dev/schemas/mcp-servers.json",
  "_comment": "Canonical MCP server definitions — Single Source of Truth. Run: bash scripts/sync-mcp-configs.sh to regenerate all platform configs.",
  "servers": {
    "sequential-thinking": {
      "package": "@modelcontextprotocol/server-sequential-thinking",
      "description": "Step-by-step chain-of-thought reasoning for complex refactors and architecture",
      "args": [],
      "env": {}
    },
    "taskmaster-ai": {
      "package": "task-master-ai",
      "description": "AI-powered task management — create, execute, and track workflow tasks",
      "args": [],
      "env": {}
    },
    "playwright": {
      "package": "@playwright/mcp@latest",
      "description": "Playwright browser automation for E2E testing",
      "args": [],
      "env": {}
    },
    "puppeteer": {
      "package": "@modelcontextprotocol/server-puppeteer",
      "description": "Headless browser automation, screenshots, scraping",
      "args": [],
      "env": {}
    },
    "context7": {
      "package": "@upstash/context7-mcp@latest",
      "description": "Library documentation lookup (React, Zustand, Vite, Electron, etc.)",
      "args": [],
      "env": {}
    },
    "fetch": {
      "package": "@modelcontextprotocol/server-fetch",
      "description": "Web page fetching for docs/research",
      "args": [],
      "env": {}
    },
    "memory": {
      "package": "@modelcontextprotocol/server-memory",
      "description": "Persistent knowledge graph across sessions",
      "args": [],
      "env": {}
    },
    "filesystem": {
      "package": "@modelcontextprotocol/server-filesystem",
      "description": "Local file operations within workspace",
      "args": ["${workspaceFolder}"],
      "env": {}
    },
    "git": {
      "package": "@modelcontextprotocol/server-git",
      "description": "Git repository operations (commit, branch, diff, log)",
      "args": ["--repository", "${workspaceFolder}"],
      "env": {}
    },
    "github": {
      "package": "@modelcontextprotocol/server-github",
      "description": "GitHub API (PRs, issues, repos, code search)",
      "args": [],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    }
  }
}
