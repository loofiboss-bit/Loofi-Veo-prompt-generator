{
  "name": "veo-prompt-generator",
  "private": true,
  "description": "Professional prompt generator for Google Veo and OpenAI Sora",
  "author": "Loofi",
  "version": "1.6.0-beta.2",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --ignore-pattern \"dist/**\" --ignore-pattern \"release/**\"",
    "lint:ci": "eslint . --max-warnings=630 --ignore-pattern \"dist/**\" --ignore-pattern \"release/**\"",
    "lint:changed:strict": "bash scripts/lint-changed-strict.sh",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --environment jsdom",
    "preview": "vite preview",
    "start": "vite preview --host --port 8080",
    "electron": "vite build && electron .",
    "electron:dev": "concurrently \"vite\" \"wait-on tcp:8080 && electron .\"",
    "dist": "vite build && electron-builder",
    "prepare": "husky",
    "validate": "npm run lint:ci && npm run typecheck && npm run test && npm run format:check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:watch": "vitest --environment jsdom",
    "test:coverage": "vitest run --environment jsdom --coverage"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint"
    ],
    "*.{ts,tsx,js,jsx,json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.10",
    "@ffmpeg/util": "^0.12.1",
    "@google/genai": "^1.41.0",
    "@mediapipe/tasks-vision": "^0.10.9",
    "@vitejs/plugin-react": "^4.3.1",
    "@xenova/transformers": "^2.17.2",
    "idb-keyval": "^6.2.1",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "jszip": "^3.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simple-peer": "^9.11.1",
    "y-webrtc": "^10.3.0",
    "yjs": "^13.6.18",
    "zundo": "^2.1.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@eslint/js": "^9.39.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.1",
    "electron": "^40.4.1",
    "electron-builder": "^26.7.0",
    "eslint": "^9.39.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.4.39",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.55.0",
    "vite": "^5.3.4",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.loofi.veo",
    "productName": "Veo Prompt Generator",
    "electronDownload": {
      "cache": "$HOME/.cache/electron",
      "mirror": "https://github.com/electron/electron/releases/download/"
    },
    "buildDependenciesFromSource": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Veo Studio"
    }
  }
}
