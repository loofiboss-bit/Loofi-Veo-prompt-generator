# Workspace reverse proxy for LAN host 192.168.1.3
# Run with Docker on Windows:
# docker compose -f infra/reverse-proxy/caddy/docker-compose.yml up -d

# Loofi Flow/Veo Studio
http://veo.local {
  reverse_proxy host.docker.internal:8080
}

# Suno AI Generator
http://suno.local {
  reverse_proxy host.docker.internal:18000
}

# Fedora Tweaks API
http://fedora-api.local {
  reverse_proxy host.docker.internal:18001
}
