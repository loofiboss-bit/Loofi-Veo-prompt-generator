# Local Ollama endpoint for prompt generation (alternative to cloud LLMs)
# Copy this file to .env.local and adjust as needed.
#
# Vite browser build
VITE_OLLAMA_BASE_URL=http://localhost:11434/v1
VITE_OLLAMA_MODEL=qwen2.5-coder:14b
#
# Node / CLI process
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5-coder:14b
