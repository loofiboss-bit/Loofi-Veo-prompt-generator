{
  "id": "markdown-export",
  "name": "Markdown Export",
  "version": "1.0.0",
  "description": "Export prompts as Markdown files",
  "author": "Loofi Flow/Veo Studio Team",
  "license": "MIT",
  "main": "index.js",
  "engineVersion": "1.4.0",
  "permissions": ["export"],
  "extensionPoints": [
    {
      "type": "export-format",
      "config": {
        "id": "markdown",
        "name": "Markdown",
        "extension": "md"
      }
    }
  ],
  "hooks": {
    "onActivate": "activate",
    "onDeactivate": "deactivate"
  }
}
