# VEO Prompt Generator - Docker Build Exclusions
# Reduces build context size, speeds up builds, excludes sensitive files

# ============================================================================
# Dependencies & Build Outputs (rebuilt inside container)
# ============================================================================
**/node_modules
dist
dist-ssr
build
release

# ============================================================================
# Version Control
# ============================================================================
**/.git
**/.gitignore
**/.gitattributes
.github

# ============================================================================
# Docker & Compose Files (not needed in image)
# ============================================================================
**/.dockerignore
**/Dockerfile*
docker-compose*
compose*.yml
compose*.yaml

# ============================================================================
# AI Tool & IDE Directories (dev-only)
# ============================================================================
.agent
.ai
.chatgpt
.claude
.codex
.copilot
.opencode
.devcontainer
.github
.gitlab
.vscode
.vs
.idea

# ============================================================================
# Build & Development Tools
# ============================================================================
.taskmaster
.workflow
.workspace
.husky
.mcp.json
.mypy_cache
__pycache__

# ============================================================================
# Test & Coverage Artifacts
# ============================================================================
test-results
playwright-report
blob-report
coverage
.pytest_cache
.ruff_cache

# ============================================================================
# Temporary Files
# ============================================================================
.tmp-*
tmpclaude-*
*.log
logs

# ============================================================================
# IDE & OS Files
# ============================================================================
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
**/.classpath
**/.project
**/.settings
**/.toolstarget
**/*.*proj.user
**/*.dbmdl
**/*.jfm

# ============================================================================
# Documentation & Configuration (not needed at runtime)
# ============================================================================
*.md
wiki
LICENSE
CHANGELOG.md
README.md
CONTRIBUTING.md
SECURITY.md
.editorconfig
.prettierrc
.prettierignore
.lint-threshold
.audit-allowlist.json

# ============================================================================
# Template & Example Files (not needed in production)
# ============================================================================
skills
templates
examples
prompt plan temp.md
sw.js
plans
docs
scripts
!scripts/serve.mjs
*.spec

# ============================================================================
# Secrets & Environment (CRITICAL: never include)
# ============================================================================
**/.env
**/.env.local
**/.env.*.local
**/secrets.dev.yaml
**/values.dev.yaml

# ============================================================================
# Package Managers & Build Systems
# ============================================================================
**/charts
**/obj
*.lock
yarn.lock
pnpm-lock.yaml
Gemfile.lock

# ============================================================================
# Pre-commit & Linting Configs
# ============================================================================
.pre-commit-config.yaml
.commitlint.config.js
eslint.config.js
.eslintignore
postcss.config.js
tsconfig.tsbuildinfo

# ============================================================================
# CI/CD & GitHub
# ============================================================================
.github/workflows
.gitlab-ci.yml
azure-pipelines.yml
.circleci

# ============================================================================
# Archive Files & Releases
# ============================================================================
*.zip
*.tar
*.tar.gz
*.rar
release
dist

# ============================================================================
# Electron & Native Bindings (if not needed in production)
# ============================================================================
# Uncomment if using production web version only:
# electron
# *.node
