{
  "name": "veo-prompt-generator",
  "private": true,
  "description": "Local-first Flow/Veo and Suno prompt studio for AI video and music workflows",
  "author": {
    "name": "loofiboss-bit",
    "email": "loofiboss-bit@users.noreply.github.com"
  },
  "version": "7.0.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "veo": "./src/cli/index.ts"
  },
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "mcp:sync": "node scripts/sync-mcp-configs.mjs",
    "mcp:check": "node scripts/sync-mcp-configs.mjs --check",
    "workspace:sync": "node scripts/sync-workspace.mjs",
    "workspace:check": "node scripts/sync-workspace.mjs --check",
    "workspace:sync:mcp": "node scripts/sync-workspace.mjs --mcp-only",
    "workspace:dry-run": "node scripts/sync-workspace.mjs --dry-run",
    "workspace:release": "node scripts/release-workspace.mjs status",
    "workspace:release:check": "node scripts/release-workspace.mjs pre-check",
    "workspace:release:tags": "node scripts/release-workspace.mjs tags",
    "agents:validate": "node scripts/validate-agent-config.mjs",
    "agents:sync": "node scripts/generate-agent-configs.mjs",
    "agents:check": "node scripts/generate-agent-configs.mjs --check",
    "version:sync": "node scripts/sync-version.mjs",
    "pre-release:check": "node scripts/pre-release-check.mjs",
    "package:rpm:check": "node scripts/check-rpm-dependencies.mjs",
    "release:prep": "npm run version:sync && npm run pre-release:check",
    "docker:push:ghcr": "node scripts/ghcr-push.mjs",
    "health:check": "node scripts/health-check.mjs",
    "health:fix": "node scripts/health-check.mjs --fix",
    "lint": "node node_modules/eslint/bin/eslint.js . --ignore-pattern \"dist/**\" --ignore-pattern \"release/**\"",
    "lint:ci": "node scripts/lint-ci.mjs",
    "lint:changed:strict": "node scripts/lint-changed-strict.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node node_modules/vitest/vitest.mjs run --environment jsdom",
    "test:ci": "npm run test:coverage && npm run coverage:check",
    "preview": "vite preview",
    "start": "vite preview --host --port 8080",
    "electron": "vite build && electron .",
    "electron:dev": "concurrently \"vite\" \"wait-on tcp:8080 && electron .\"",
    "dist": "vite build && electron-builder",
    "prepare": "husky",
    "validate": "npm run mcp:check && npm run theme:check && npm run agents:check && npm run models:check && npm run lint:ci && npm run typecheck && npm run test && npm run format:check",
    "models:check": "node scripts/check-executable-models.mjs",
    "validate:release": "npm run health:check && npm run package:rpm:check && npm run pre-release:check && npm run validate && npm run build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:watch": "node node_modules/vitest/vitest.mjs --environment jsdom",
    "test:coverage": "node node_modules/vitest/vitest.mjs run --environment jsdom --coverage",
    "coverage:check": "node scripts/check-coverage.mjs",
    "test:e2e": "npx playwright test --project=chromium",
    "test:e2e:all": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "verify:staging:screenshots": "node scripts/capture-staging-screenshots.mjs",
    "screenshots": "node scripts/capture-screenshots.mjs",
    "release:checksums": "node scripts/generate-checksums.mjs",
    "cli": "node --import tsx src/cli/index.ts",
    "cli:help": "node --import tsx src/cli/index.ts --help",
    "theme:check": "node scripts/check-theme-classes.mjs"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint"
    ],
    "*.{ts,tsx,js,jsx,json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.10",
    "@ffmpeg/util": "^0.12.1",
    "@google/genai": "^2.11.0",
    "@mediapipe/tasks-vision": "^0.10.9",
    "@xenova/transformers": "^2.17.2",
    "events": "^3.3.0",
    "google-auth-library": "^10.9.0",
    "i18next": "^26.3.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "idb-keyval": "^6.2.1",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.7",
    "jszip": "^3.10.1",
    "keytar": "^7.9.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.9",
    "react-router-dom": "^7.18.1",
    "simple-peer": "^9.11.1",
    "y-webrtc": "^10.3.0",
    "yjs": "^13.6.18",
    "zundo": "^2.1.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.1",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.4.39",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wait-on": "^9.0.4"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "onnxruntime-web": "1.27.0",
    "protobufjs": "7.6.4"
  },
  "build": {
    "appId": "com.loofi.flowveostudio",
    "productName": "Loofi Flow Veo Studio",
    "buildDependenciesFromSource": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "publish": {
      "provider": "github",
      "owner": "loofiboss-bit",
      "repo": "Loofi-Veo-prompt-generator"
    },
    "linux": {
      "target": [
        "AppImage",
        "rpm"
      ],
      "category": "Utility"
    },
    "appImage": {
      "artifactName": "Loofi-Flow-Veo-Studio-${version}-linux-${arch}.${ext}"
    },
    "rpm": {
      "maintainer": "loofiboss-bit <loofiboss-bit@users.noreply.github.com>",
      "depends": [
        "gtk3",
        "libnotify",
        "nss",
        "libXScrnSaver",
        "libXtst",
        "xdg-utils",
        "at-spi2-core",
        "libuuid"
      ],
      "vendor": "Loofi",
      "artifactName": "Loofi-Flow-Veo-Studio-${version}-linux-${arch}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Loofi-Flow-Veo-Studio-${version}-${os}-${arch}-setup.${ext}"
    },
    "portable": {
      "artifactName": "Loofi-Flow-Veo-Studio-${version}-${os}-${arch}-portable.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Loofi Flow Veo Studio"
    }
  }
}
