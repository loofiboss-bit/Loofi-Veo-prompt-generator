{
  "mcpServers": {
    "docker-mcp": {
      "type": "stdio",
      "command": "docker",
      "args": ["mcp", "gateway", "run"]
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post-tool-use.cjs"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post-tool-use.cjs"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre-tool-use.cjs"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre-tool-use.cjs"
          }
        ]
      }
    ]
  },
  "platform": "claude",
  "models": {
    "high": "opus",
    "medium": "sonnet",
    "low": "haiku"
  },
  "agents": {
    "project-coordinator": { "model": "opus", "color": "red" },
    "architecture-advisor": { "model": "sonnet", "color": "yellow" },
    "backend-builder": { "model": "sonnet", "color": "orange" },
    "frontend-integration-builder": { "model": "sonnet", "color": "yellow" },
    "code-implementer": { "model": "sonnet", "color": "pink" },
    "test-writer": { "model": "haiku", "color": "purple" },
    "release-planner": { "model": "haiku", "color": "cyan" }
  },
  "memoryDir": ".claude/agent-memory",
  "agentFormat": "chatagent"
}
